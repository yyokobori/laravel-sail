# ============================================================================
# .env.example - ローカル開発環境の環境変数テンプレート
# ============================================================================
# このファイルは start.sh で app/backend/.env にコピーされ、
# Docker コンテナの環境変数として使用されます。
# 
# 【重要】新しい設定項目を Laravel に追加する場合は、このファイルも
# 更新してください。更新しないとデグレード（機能喪失）につながります。
# ============================================================================

# アプリケーション
APP_NAME="Laravel Sail"
APP_ENV=local
APP_KEY=base64:5vUJ3VrhjXvffuLT5Zs+VZRQ/UZ/wZEch/MmGnKpt0w=
APP_DEBUG=true
APP_URL=http://localhost:80
APP_TIMEZONE=Asia/Tokyo

# sail実行のためのサービス指定
APP_SERVICE=backend

# ユーザーとグループ (ホストマシンのユーザーIDとグループIDを指定)
WWWUSER=1000
WWWGROUP=1000

# データベース (MySQL - Docker Sail経由)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sail
DB_USERNAME=sail
DB_PASSWORD=sail

# キャッシュ
CACHE_DRIVER=file
CACHE_PASSWORD=null

# セッション
SESSION_DRIVER=file
SESSION_LIFETIME=120

# キュー
QUEUE_CONNECTION=sync

# メール (開発環境では log ドライバを使用)
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO (オプション - ローカル開発用)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_ENDPOINT=http://s3:9000
AWS_USE_PATH_STYLE_ENDPOINTS=true

# フロントエンド (Vite)
VITE_PORT=8000
VITE_API_BASE_URL=http://localhost

# ログ
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DEVELOP_DAYS=7
LOG_ERROR_DAYS=14
LOG_INFO_DAYS=14